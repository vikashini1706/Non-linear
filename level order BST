import java .util.*;
class Main
{
	public static void main(String[]args)
	{
		Scanner sc=new Scanner(System.in);
		int n=sc.nextInt();
		Node root = null;
		for(int i=0;i<n;i++)
		{
			int val=sc.nextInt();
			root=build(root,val);
		}
		
		level(root);

	}
	public static Node build(Node root,int val)
	{
		if(root==null) return new Node(val);
		if(val<root.data) root.left=build(root.left,val);
		if(val>root.data) root.right=build(root.right,val);
		return root;
	}
	public static void level(Node root)
	{
	    Queue<Node> q=new LinkedList<>();
	    q.offer(root);
	    while(!q.isEmpty())
	    {
	        Node t=q.poll();
	        System.out.print(t.data +" ");
	        if(t.left!=null)
	        q.offer(t.left);
	        
	        if(t.right!=null)
	        q.offer (t.right);
	    }
	}
	
}
class Node{
	int data;
	Node right,left;
	Node(int data)
	{
		this.data=data;
		left=right=null;
	}
}
